<section class="main-visual">
    <div class="main-visual-container">
        <h1>
            <img class="main-visual-logo" src="/gnjb-utawari-note/logo-hz.svg">
        </h1>
        <p class="text-body">観測者による観測者のための歌割り記録ツール</p>
    </div>
</section>

<style>
    .main-visual {
        position: relative;
        width: 100%;
        height: 240px;
        background-color: var(--color-bg);
        border: 2px solid var(--color-primary);
        box-sizing: border-box;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        overflow: hidden;
    }

    .main-visual-container h1 {
        margin: 0;
        padding: 0;
        font-size: 100%;
        line-height: 1;
    }

    .main-visual-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .main-visual-logo {
        width: auto;
        height: 92px;
        max-width: 90%;
    }

    .main-visual::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 60px 80px 0 0;
        border-color: var(--color-primary) transparent transparent transparent;
        pointer-events: none;
    }

    .main-visual::after {
        content: "";
        position: absolute;
        bottom: 0;
        right: 0;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 0 0 60px 80px;
        border-color: transparent transparent var(--color-primary) transparent;
        pointer-events: none;
    }

    @media (min-width: 1024px) {
        .main-visual {
            height: 600px;
            border: 5px solid var(--color-primary);
        }

        .main-visual-container {
            gap: 20px;
        }

        .main-visual-logo {
            height: 200px;
        }

        .main-visual::before {
            border-width: 240px 320px 0 0;
        }

        .main-visual::after {
            border-width: 0 0 240px 320px;
        }
    }
</style>