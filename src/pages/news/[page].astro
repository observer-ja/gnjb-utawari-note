---
import type { GetStaticPathsOptions } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import NewsItem from '../../components/NewsItem.astro';
import { newsData } from '../../data/news';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    return paginate(newsData, { pageSize: 10 });
}

const { page } = Astro.props
---

<Layout title='更新情報'>
    <PageHeader title="更新情報" />
    <div class="container">
        <ul class="news-list">
            {
                page.data.map((item) => (
                    <NewsItem date={item.date} text={item.text} url={item.url} />
                ))
            }
        </ul>
        <div class="pagination">
            {
                page.url.prev ? (
                    <a href={page.url.prev} class="page-btn prev text-body">PREV</a>
                ) : (
                    <span class="page-btn prev text-body disabled">PREV</span>
                )
            }
            {
                page.url.next ? (
                    <a href={page.url.next} class="page-btn next text-body">NEXT</a>
                ) : (
                    <span class="page-btn next text-body disabled">NEXT</span>
                )
            }
        </div>
    </div>
</Layout>

<style>
    .news-list {
        display: flex;
        flex-direction: column;
        padding: 0 20px;
        gap: 12px;
        margin: 0;
        list-style: none;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 32px;
    }

    .page-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        text-decoration: none;
        color: inherit;
    }

    .page-btn.prev::before {
        content: "";
        width: 20px;
        height: 20px;
        background-color: var(--color-text);
        -webkit-mask: url('/gnjb-utawari-note/icon-arrow-left.svg') no-repeat center / contain;
        mask: url('/gnjb-utawari-note/icon-arrow-left.svg') no-repeat center / contain;
    }

    .page-btn.next::after {
        content: "";
        width: 20px;
        height: 20px;
        background-color: var(--color-text);
        -webkit-mask: url('/gnjb-utawari-note/icon-arrow-right.svg') no-repeat center / contain;
        mask: url('/gnjb-utawari-note/icon-arrow-right.svg') no-repeat center / contain;
    }

    .page-btn.disabled {
        opacity: 0.3;
        pointer-events: none;
        cursor: default;
    }

    @media (min-width: 1024px) {
        .news-list {
            padding: 0 48px;
        }

        .pagination{
            gap: 64px;
        }
    }
</style>